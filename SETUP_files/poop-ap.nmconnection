[connection]
id=poop-ap
uuid=32e07431-3dd2-4297-93f1-0c45551b58f8
type=wifi
interface-name=wlan0
autoconnect=false

[wifi]
mode=ap
ssid=poop
band=bg
channel=6

[wifi-security]
key-mgmt=wpa-psk
psk=pooppoop
proto=rsn;
pairwise=ccmp;
group=ccmp;
pmf=1

[ipv4]
method=shared
address1=192.168.4.1/24

[ipv6]
method=disabled
